# Article Storage Backend Environment Variables

# Sanity CMS
SANITY_PROJECT_ID=y7j5j2mt
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=your_sanity_token

# Server Configuration
PORT=5000
# Set to 'production' on Afrihost so the backend also serves frontend static files
NODE_ENV=production

# Frontend URL(s) for CORS (comma-separated)
# Only needed when serving frontend separately via Apache.
# In production (Node.js serving frontend), this can be left as your domain.
FRONTEND_URL=https://yourdomain.co.za

# ── Afrihost: path to the compiled frontend dist folder ───────────────────────
# Default (relative): <project-root>/frontend/dist
# On Afrihost, set this to the absolute path if your folder layout differs, e.g.:
# FRONTEND_DIST_PATH=/home/cpanelusername/dev-landing-page/frontend/dist
