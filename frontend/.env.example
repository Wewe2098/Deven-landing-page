# Frontend Environment Variables

# ── Afrihost ──────────────────────────────────────────────────────────────────
# Option A – Node.js serves everything: point API to same domain
# VITE_API_URL=https://yourdomain.co.za/api
#
# Option B – Apache serves frontend, Node.js runs on a separate port:
# VITE_API_URL=https://yourdomain.co.za/api   (Apache proxies /api → Node.js)
# ─────────────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
VITE_SANITY_PROJECT_ID=y7j5j2mt
VITE_SANITY_DATASET=production
VITE_SITE_URL=http://localhost:5173
